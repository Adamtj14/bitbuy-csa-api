# Copy to .env next to docker-compose.yml and fill in.

# Public URL the app is served from (Google OAuth redirects here).
BASE_URL=https://ccml.ai

# Any long random strings:  openssl rand -hex 32  /  openssl rand -hex 24
SESSION_SECRET=
AGENT_TOKEN=

# Google OAuth client (redirect URI: $BASE_URL/auth/google/callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bitbuy CSA feed URL for crypto quotes on the Pi agent (optional here)
# CSA_FEED_URL=
